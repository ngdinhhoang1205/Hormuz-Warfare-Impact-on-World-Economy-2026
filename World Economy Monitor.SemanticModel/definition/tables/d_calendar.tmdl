	partition d_calendar = calculated
		mode: import
		source = ```
				
				VAR _AllDates = 
				    UNION(
				        SELECTCOLUMNS(f_cb_policy_rates, "Date", f_cb_policy_rates[period]),
				        SELECTCOLUMNS(f_consumer_price_index, "Date", f_consumer_price_index[period]),
				        SELECTCOLUMNS(f_gross_domestic_product, "Date", f_gross_domestic_product[period]),
				        SELECTCOLUMNS(f_industrial_production_index, "Date", f_industrial_production_index[Date]),
				        SELECTCOLUMNS(f_PMI, "Date", f_PMI[period]),
				        SELECTCOLUMNS(f_retail_sales, "Date", f_retail_sales[period]),
				        SELECTCOLUMNS(f_trade_balance, "Date", f_trade_balance[period]),
				        SELECTCOLUMNS(f_unemployment_rate, "Date", f_unemployment_rate[period])
				    )
				
				VAR _StartDate = MINX(_AllDates, [Date])
				VAR _EndDate   = MAXX(_AllDates, [Date])
				
				RETURN
				    ADDCOLUMNS(
				        CALENDAR(_StartDate, _EndDate),
				        "Year", YEAR([Date]),
				        "Month No", MONTH([Date]),
				        "Month", FORMAT([Date], "mmm"),
				        "Year-Month", FORMAT([Date], "yyyy-mm"),
				        "YearMonth", YEAR([Date])*100+MONTH([Date]),
				        "Quarter", "Q" & FORMAT([Date], "q"),
				        "Year-Quarter", FORMAT([Date], "yyyy") & "-Q" & FORMAT([Date], "q")
				    )
				```

	annotation PBI_Id = 636fb59272a8481e988929e72e7040b6

